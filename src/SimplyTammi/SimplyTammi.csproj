<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
    <UserSecretsId>e331ff72-e97e-4ae9-94ed-ae03550ace82</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <Content Remove="wwwroot\images\imageresize.ps1" />
  </ItemGroup>

  <ItemGroup>
    <None Include=".github\docs\branching-strategy.md" />
    <None Include=".github\docs\setup-instructions.md" />
    <None Include=".github\workflows\branch-protection.yml" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Postmark" Version="5.3.0" />
  </ItemGroup>

  <!-- npm/Tailwind CSS Integration - Optional (manual setup required) -->
  <!-- To enable automatic builds, ensure npm is in PATH and run: npm install -->
  <Target Name="NpmInstall" BeforeTargets="Build" Condition="'$(SKIP_NPM_BUILD)' != 'true'">
    <Exec Command="cmd /c npm install" ContinueOnError="true" />
  </Target>

  <Target Name="BuildTailwind" AfterTargets="NpmInstall" BeforeTargets="Build" Condition="'$(SKIP_NPM_BUILD)' != 'true'">
    <Exec Command="cmd /c npm run build:css" ContinueOnError="true" />
  </Target>

</Project>
