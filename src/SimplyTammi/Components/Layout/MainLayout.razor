@inherits LayoutComponentBase

<div class="flex min-h-screen bg-gray-50">
    <aside class="w-64 bg-white shadow-md">
        <NavMenu />
    </aside>

    <main class="flex-1 flex flex-col">
        <div class="bg-white border-b border-gray-200 px-6 py-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" class="text-blue-600 hover:text-blue-800 font-medium">
                About
            </a>
        </div>

        <article class="flex-1 px-6 py-8 max-w-7xl w-full mx-auto">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet class="fixed bottom-0 left-0 right-0 bg-red-100 border-t-4 border-red-600 p-4">
    <p class="text-red-800 font-semibold">An unhandled error has occurred.</p>
    <a href="." class="text-red-600 hover:text-red-800 font-medium">Reload</a>
    <button onclick="document.getElementById('blazor-error-ui').style.display='none'" class="ml-4 text-red-600 hover:text-red-800 text-xl">🗙</button>
</div>
