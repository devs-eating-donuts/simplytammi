@rendermode InteractiveServer
@using SimplyTammi.Models

<section id="gallery" class="scroll-mt-16 mx-auto max-w-6xl px-4 py-12">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
            <h2 class="text-2xl font-semibold">Featured Work</h2>
            <p class="mt-2 text-neutral-400">A selection of images from nature, travel, animals, and black and white photography.</p>
        </div>

        <div class="flex flex-wrap gap-2">
            @foreach (var t in tabs)
            {
                <button class="btn @(active == t ? "btn-primary" : "btn-ghost")"
                        @onclick="() => active = t">
                    @t
                </button>
            }
        </div>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        @foreach (var s in Filtered)
        {
            <article class="group overflow-hidden rounded-2xl border border-neutral-700 bg-neutral-900 shadow-sm">
                <div class="aspect-[4/3] overflow-hidden">
                    <img class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.02]"
                         src="@s.ThumbUrl" alt="@s.Title" />
                </div>
                <div class="p-4">
                    <p class="text-xs uppercase tracking-[0.2em] text-neutral-400">@s.Category</p>
                    <h3 class="mt-1 font-semibold">@s.Title</h3>
                </div>
            </article>
        }
    </div>
</section>

