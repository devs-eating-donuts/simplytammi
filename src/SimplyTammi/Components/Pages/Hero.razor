<section class="mx-auto max-w-6xl px-4 pt-14 pb-10">
    <div class="grid items-center gap-10 md:grid-cols-2">
        <div>
            <p class="text-sm uppercase tracking-[0.2em] text-neutral-400">Photography By</p>

            <h1 class="mt-3 text-4xl md:text-5xl font-semibold leading-tight">
                simply tammi
            </h1>

            <p class="mt-4 text-neutral-400 text-lg leading-relaxed">
                Clean compositions. Soft light. Bold subjects.
            </p>

            <div class="mt-7 flex flex-wrap gap-3">
                <a class="btn btn-primary" href="#portfolio">See My Images</a>
                <a class="btn btn-ghost" href="#contact">Get in Touch</a>
            </div>
        </div>

        <div class="relative">
            <div class="aspect-[4/5] overflow-hidden rounded-[2rem] border border-neutral-700">
                <img class="h-full w-full object-cover"
                     src="images/aspens.jpg"
                     alt="Featured photo - Aspens in Colorado" />
            </div>

            <!-- subtle "soft" overlay to keep UI calm -->
            <div class="pointer-events-none absolute inset-0 rounded-[2rem] ring-1 ring-white/5"></div>
        </div>
    </div>
</section>

