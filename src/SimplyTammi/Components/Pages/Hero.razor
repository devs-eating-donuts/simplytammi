<section id="home" class="mx-auto max-w-6xl px-4 pt-14 pb-10">
    <div class="grid items-center gap-10 md:grid-cols-2">
        <div>
            <p class="text-sm uppercase tracking-[0.2em] text-neutral-400">Photography By</p>

            <h1 class="mt-3 text-4xl sm:text-5xl md:text-5xl font-semibold leading-tight">
                simplytammi
            </h1>

            <p class="mt-4 text-base sm:text-lg text-neutral-400 leading-relaxed">
                Welcome to <i>simplytammi</i>. Photography is my way of slowing down and noticing the moments
                that often pass us by. I love the timeless feel of black and white images, but I’m also
                drawn to the beauty of nature, the personality of animals, and the stories found in the
                places I travel. Each photograph is a small glimpse of the world as I experienced it through my lens.
            </p>

            <div class="mt-7 flex flex-wrap gap-3">
                <a class="btn btn-primary" href="#gallery">View Gallery</a>
                <a class="btn btn-ghost" href="#contact">Say Hello</a>
            </div>
        </div>

        <div class="relative">
            <div class="aspect-[4/5] overflow-hidden rounded-[2rem] border border-neutral-700">
                <img class="h-full w-full object-cover"
                     src="images/aspens.jpg"
                     alt="Featured photo - Aspens in Colorado" />
            </div>

            <!-- subtle "soft" overlay to keep UI calm -->
            <div class="pointer-events-none absolute inset-0 rounded-[2rem] ring-1 ring-white/5"></div>
        </div>
    </div>
</section>

