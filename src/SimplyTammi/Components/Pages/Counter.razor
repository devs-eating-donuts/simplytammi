@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<div class="max-w-md mx-auto">
    <div class="bg-white rounded-xl shadow-lg p-8 border-t-4 border-indigo-600">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Counter</h1>
        <p class="text-gray-600 mb-8">Interactive component demonstration with real-time updates.</p>

        <div class="bg-gradient-to-r from-indigo-50 to-blue-50 rounded-lg p-8 text-center mb-8">
            <p class="text-gray-600 text-sm font-medium mb-2">Current Count</p>
            <p class="text-6xl font-bold text-indigo-600">@currentCount</p>
        </div>

        <button class="w-full bg-indigo-600 text-white font-semibold py-3 rounded-lg hover:bg-indigo-700 transition active:scale-95 mb-4"
                @onclick="IncrementCount">
            ➕ Click to Increment
        </button>
        
        <button class="w-full bg-red-600 text-white font-semibold py-3 rounded-lg hover:bg-red-700 transition active:scale-95"
                @onclick="ResetCount">
            🔄 Reset
        </button>

        <div class="mt-8 p-4 bg-blue-50 rounded-lg border-l-4 border-blue-600">
            <p class="text-sm text-blue-900">
                <strong>💡 Tip:</strong> This component is interactive and updates in real-time using server-side rendering.
            </p>
        </div>
    </div>
</div>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }

    private void ResetCount()
    {
        currentCount = 0;
    }
}
